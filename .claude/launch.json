{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "watch", "packages/server/src/index.ts"],
      "port": 3001
    },
    {
      "name": "client",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace=@wikihop/client"],
      "port": 5173
    },
    {
      "name": "production",
      "runtimeExecutable": "node",
      "runtimeArgs": ["packages/server/dist/index.js"],
      "port": 3001,
      "env": {
        "NODE_ENV": "production"
      }
    }
  ]
}
